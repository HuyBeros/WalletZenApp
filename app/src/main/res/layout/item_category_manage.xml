<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="14dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeColor="#E2E8F0"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Row 1: Icon + Name + Type badge + Actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Emoji Icon Circle -->
            <TextView
                android:id="@+id/tvCatIcon"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:gravity="center"
                android:textSize="20sp"
                android:background="@drawable/bg_icon_circle"
                android:backgroundTint="#F1F5F9"
                android:text="💰" />

            <!-- Name + Type badge -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvCatName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ăn uống"
                    android:textColor="#1E293B"
                    android:textStyle="bold"
                    android:textSize="15sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">

                    <!-- Type badge (CHI/THU) -->
                    <TextView
                        android:id="@+id/tvCatType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CHI TIÊU"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="#EF4444"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="2dp"
                        android:background="@drawable/bg_badge_red" />

                    <!-- Budget status badge -->
                    <TextView
                        android:id="@+id/tvBudgetStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✅ Ổn"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="#059669"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="2dp"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/bg_badge_green"
                        android:visibility="gone" />

                </LinearLayout>

            </LinearLayout>

            <!-- Action buttons -->
            <ImageView
                android:id="@+id/btnEditCategory"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/edit"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#378ADD" />

            <ImageView
                android:id="@+id/btnDeleteCategory"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/delete"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#EF4444" />

        </LinearLayout>

        <!-- Row 2: Budget info (only for CHI / expense categories) -->
        <LinearLayout
            android:id="@+id/layoutBudgetInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            android:visibility="gone">

            <!-- Spending / Limit row -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tvSpent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đã dùng: 0đ"
                    android:textSize="12sp"
                    android:textColor="#64748B"
                    android:layout_alignParentStart="true" />

                <TextView
                    android:id="@+id/tvLimit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hạn mức: Chưa đặt"
                    android:textSize="12sp"
                    android:textColor="#64748B"
                    android:layout_alignParentEnd="true" />

            </RelativeLayout>

            <!-- Progress bar -->
            <ProgressBar
                android:id="@+id/progressBudget"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:progress="0"
                android:progressDrawable="@drawable/bg_progress_bar_budget"
                android:layout_marginTop="6dp" />



        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>

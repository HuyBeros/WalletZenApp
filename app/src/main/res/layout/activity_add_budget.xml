<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <!-- Top Navigation Bar -->
    <LinearLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="#FFFFFF">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_revert"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#1E3A8A" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Thêm ngân sách"
            android:textColor="#1E3A8A"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginEnd="40dp" />
    </LinearLayout>

    <!-- Bottom Save Button Container -->
    <LinearLayout
        android:id="@+id/layoutBottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:padding="20dp"
        android:background="#FFFFFF">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveBudget"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="#2563EB"
            android:text="Lưu ngân sách"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            app:cornerRadius="16dp"
            app:icon="@drawable/ic_payments"
            app:iconGravity="textStart"
            app:iconTint="#FFFFFF" />
    </LinearLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/layoutHeader"
        android:layout_above="@id/layoutBottom"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <!-- Limit Input Container (Visible for Chi tiêu, Gone for Thu nhập) -->
            <LinearLayout
                android:id="@+id/layoutLimitContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hạn mức ngân sách"
                    android:textColor="#64748B"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="20dp" />

                <!-- Currency + Large Amount input -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="32dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="đ"
                        android:textColor="#1E40AF"
                        android:textSize="44sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif"
                        android:layout_marginEnd="12dp" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtBudgetLimit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="120dp"
                        android:inputType="number"
                        android:hint="0"
                        android:textColorHint="#94A3B8"
                        android:textSize="48sp"
                        android:fontFamily="sans-serif-medium"
                        android:textStyle="bold"
                        android:textColor="#1E293B"
                        android:background="@null"
                        android:gravity="center"
                        android:maxLength="10" />
                </LinearLayout>
            </LinearLayout>

            <!-- CHI TIÊU / THU NHẬP Toggle Pill Segment -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_toggle_container"
                android:backgroundTint="#F1F5F9"
                android:padding="4dp"
                android:layout_marginBottom="32dp">

                <TextView
                    android:id="@+id/chipExpense"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="Chi tiêu"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:background="@drawable/bg_toggle_selected"
                    android:backgroundTint="#1E40AF" />

                <TextView
                    android:id="@+id/chipIncome"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="Thu nhập"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#64748B"
                    android:gravity="center"
                    android:background="@android:color/transparent" />
            </LinearLayout>

            <!-- Category Name Input Field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutCatName"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Tên danh mục"
                app:boxCornerRadiusTopStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxStrokeColor="#2563EB"
                app:boxStrokeWidthFocused="2dp"
                app:hintTextColor="#2563EB"
                android:layout_marginBottom="24dp">

                <AutoCompleteTextView
                    android:id="@+id/edtCategoryName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:maxLines="1"
                    android:textSize="16sp"
                    android:textColor="#1E293B"
                    android:padding="20dp"
                    android:fontFamily="sans-serif-medium"
                    android:paddingVertical="18dp"
                    android:completionThreshold="1" />
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>
    </ScrollView>
</RelativeLayout>

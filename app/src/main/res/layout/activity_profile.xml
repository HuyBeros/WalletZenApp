<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6F8">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNavigation"
        android:fillViewport="true"
        android:scrollbars="none">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- BLUE HEADER BACKGROUND -->
            <View
                android:id="@+id/headerBg"
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:background="@color/primary" />



            <!-- PROFILE AVATAR & NAME -->
            <LinearLayout
                android:id="@+id/llProfileHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="16dp">

                <RelativeLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <!-- Avatar Circle -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/avatarCard"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        app:cardCornerRadius="50dp"
                        app:cardBackgroundColor="#4DFFFFFF"
                        app:cardElevation="0dp"
                        android:layout_centerInParent="true">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_gravity="center"
                            android:src="@drawable/person"
                            app:tint="#FFFFFF" />
                    </androidx.cardview.widget.CardView>

                    <!-- Edit Icon Badge -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        app:cardCornerRadius="16dp"
                        app:cardBackgroundColor="#FFFFFF"
                        app:cardElevation="2dp"
                        android:layout_alignBottom="@+id/avatarCard"
                        android:layout_alignEnd="@+id/avatarCard"
                        android:layout_marginStart="68dp"
                        android:layout_marginTop="68dp">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_gravity="center"
                            android:src="@drawable/edit"
                            app:tint="@color/primary" />
                    </androidx.cardview.widget.CardView>
                </RelativeLayout>

                <TextView
                    android:id="@+id/tvDisplayName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Người dùng"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvUsername"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@username"
                    android:textColor="#CCFFFFFF"
                    android:textSize="14sp" />
                
                <!-- Hidden TV for Email Display to satisfy Java code -->
                <TextView
                    android:id="@+id/tvEmailDisplay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- CARD 1: UPDATE INFO -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardUpdateInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/llProfileHeader"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Title -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="20dp">

                        <androidx.cardview.widget.CardView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            app:cardCornerRadius="18dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#EAF2FD">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_gravity="center"
                                android:src="@drawable/edit"
                                app:tint="@color/primary" />
                        </androidx.cardview.widget.CardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="Cập nhật thông tin"
                            android:textColor="@color/text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Full Name Field -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Họ và tên"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false"
                        app:startIconDrawable="@drawable/edit"
                        app:startIconTint="@color/text_hint"
                        app:boxBackgroundColor="#F4F5F9"
                        app:boxStrokeWidth="0dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        android:layout_marginBottom="16dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtFullName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Nguyễn Văn A"
                            android:paddingVertical="14dp"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Email Field -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false"
                        app:startIconDrawable="@drawable/mail"
                        app:startIconTint="@color/text_hint"
                        app:boxBackgroundColor="#F4F5F9"
                        app:boxStrokeWidth="0dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        android:layout_marginBottom="24dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="username@email.com"
                            android:inputType="textEmailAddress"
                            android:paddingVertical="14dp"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Save Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnUpdateInfo"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="LƯU THÔNG TIN"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:backgroundTint="#002A88"
                        app:cornerRadius="12dp"
                        app:icon="@android:drawable/ic_menu_save"
                        app:iconGravity="textStart" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARD 2: CHANGE PASSWORD -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardChangePassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/cardUpdateInfo"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Title -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="20dp">

                        <androidx.cardview.widget.CardView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            app:cardCornerRadius="18dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#FDE8E8">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_gravity="center"
                                android:src="@android:drawable/ic_lock_lock"
                                app:tint="#C53030" />
                        </androidx.cardview.widget.CardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="Đổi mật khẩu"
                            android:textColor="@color/text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Old Password Field -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mật khẩu cũ"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false"
                        app:startIconDrawable="@android:drawable/ic_lock_lock"
                        app:startIconTint="@color/text_hint"
                        app:passwordToggleEnabled="true"
                        app:passwordToggleTint="@color/text_secondary"
                        app:boxBackgroundColor="#F4F5F9"
                        app:boxStrokeWidth="0dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        android:layout_marginBottom="16dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtOldPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Nhập mật khẩu hiện tại"
                            android:inputType="textPassword"
                            android:paddingVertical="14dp"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- New Password Field -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mật khẩu mới"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false"
                        app:startIconDrawable="@android:drawable/ic_lock_lock"
                        app:startIconTint="@color/text_hint"
                        app:passwordToggleEnabled="true"
                        app:passwordToggleTint="@color/text_secondary"
                        app:boxBackgroundColor="#F4F5F9"
                        app:boxStrokeWidth="0dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        android:layout_marginBottom="24dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtNewPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Nhập mật khẩu mới"
                            android:inputType="textPassword"
                            android:paddingVertical="14dp"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Save Password Button -->
                    <!-- In the image there is no "LƯU MẬT KHẨU" button? Ah, wait, there is no button in the second card in the image!
                         Wait, the user's design image has NO save button for password! Let's check the image again.
                         Ah! The second card in the image ONLY has the two inputs: "Mật khẩu cũ" and "Mật khẩu mới". 
                         Wait, there is no save button? How do they save it? Maybe it auto-saves or there's a missing part of the scroll.
                         But the java code `ProfileActivity.java` explicitly expects `btnChangePassword = findViewById(R.id.btnChangePassword);`.
                         To keep java working without crash, I should add a hidden or visible save button, or just add it normally because users MUST have a way to save. I will add it like the "LƯU THÔNG TIN" button but named "LƯU MẬT KHẨU". -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnChangePassword"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="CẬP NHẬT MẬT KHẨU"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:backgroundTint="#C53030"
                        app:cornerRadius="12dp"
                        app:icon="@android:drawable/ic_menu_save"
                        app:iconGravity="textStart" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- LOGOUT BUTTON -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_below="@id/cardChangePassword"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="32dp"
                android:text="Đăng xuất khỏi thiết bị"
                android:textColor="#C53030"
                android:textSize="15sp"
                app:strokeColor="#E2E8F0"
                app:strokeWidth="1dp"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_menu_revert"
                app:iconTint="#C53030"
                app:iconGravity="textStart" />

        </RelativeLayout>
    </ScrollView>

    <!-- BOTTOM NAVIGATION -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        app:itemIconTint="@color/nav_item_color"
        app:itemTextColor="@color/nav_item_color"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu"
        app:elevation="8dp" />

</RelativeLayout>
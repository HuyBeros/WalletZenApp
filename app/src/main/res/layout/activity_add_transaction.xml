<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- ======================== FIXED SAVE BUTTON (Bottom) ======================== -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="24dp"
        android:backgroundTint="@color/primary_light"
        android:text="LƯU GIAO DỊCH"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:fontFamily="sans-serif-medium"
        android:textStyle="bold"
        android:letterSpacing="0.06"
        app:cornerRadius="16dp"
        app:elevation="6dp"
        app:icon="@drawable/create_gd"
        app:iconGravity="textStart"
        app:iconTint="#FFFFFF"
        app:iconSize="20dp" />

    <!-- ======================== SCROLLABLE CONTENT ======================== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/btnSave"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== BLUE HEADER ZONE ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/primary_light"
                android:paddingBottom="52dp">

                <!-- Top bar: back + title + menu -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="44dp"
                    android:paddingBottom="8dp">

                    <ImageView
                        android:id="@+id/btnBack"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        android:padding="10dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:tint="#FFFFFF" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Thêm giao dịch"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-medium"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@android:drawable/ic_menu_more"
                        android:padding="10dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:tint="#FFFFFF" />
                </LinearLayout>

                <!-- "SỐ TIỀN" label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SỐ TIỀN"
                    android:textColor="#CCE8F4FF"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.12"
                    android:gravity="center"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp" />

                <!-- Currency symbol + Amount input row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:layout_marginBottom="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="đ"
                        android:textColor="#99DBEEFF"
                        android:textSize="32sp"
                        android:fontFamily="sans-serif"
                        android:layout_marginEnd="8dp"
                        android:layout_marginTop="12dp" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="60dp"
                        android:inputType="numberDecimal"
                        android:hint="0"
                        android:textColorHint="#66B8DFFF"
                        android:textSize="64sp"
                        android:fontFamily="sans-serif-medium"
                        android:textStyle="bold"
                        android:textColor="#E8F4FF"
                        android:background="@null"
                        android:gravity="center"
                        android:maxLength="10"
                        android:includeFontPadding="false" />
                </LinearLayout>

                <!-- ===== TYPE TOGGLE (Pill segment) ===== -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_gravity="center_horizontal"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_toggle_container"
                    android:padding="4dp">

                    <!-- Chi tiêu (selected by default) -->
                    <TextView
                        android:id="@+id/chipExpense"
                        android:layout_width="140dp"
                        android:layout_height="match_parent"
                        android:text="Chi tiêu"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium"
                        android:textStyle="bold"
                        android:textColor="@color/primary_light"
                        android:gravity="center"
                        android:background="@drawable/bg_toggle_selected" />

                    <!-- Thu nhập (unselected) -->
                    <TextView
                        android:id="@+id/chipIncome"
                        android:layout_width="140dp"
                        android:layout_height="match_parent"
                        android:text="Thu nhập"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="#CCE8F4FF"
                        android:gravity="center"
                        android:background="@android:color/transparent" />
                </LinearLayout>
            </LinearLayout>

            <!-- ===== WHITE FORM CARD (overlaps blue) ===== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="-28dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- DANH MỤC label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DANH MỤC"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="10dp" />

                    <!-- Dropdown danh mục -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false"
                        app:startIconDrawable="@drawable/categorie"
                        app:startIconTint="@color/primary_light"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="@color/border"
                        app:boxStrokeWidth="1dp"
                        app:boxBackgroundColor="#F7F9FB">

                        <AutoCompleteTextView
                            android:id="@+id/spinnerCategory"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:paddingVertical="14dp"
                            android:hint="Chọn danh mục"
                            android:textColorHint="@color/text_hint"
                            android:textColor="@color/text_primary"
                            android:fontFamily="sans-serif"
                            android:textSize="15sp" />
                    </com.google.android.material.textfield.TextInputLayout>



                    <!-- GHI CHÚ -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GHI CHÚ"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.1"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="10dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false"
                        app:endIconDrawable="@android:drawable/ic_menu_camera"
                        app:endIconTint="@color/text_hint"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="@color/border"
                        app:boxStrokeWidth="1dp"
                        app:boxBackgroundColor="#F7F9FB">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtNote"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Nhập ghi chú hoặc đính kèm ảnh..."
                            android:textColorHint="@color/text_hint"
                            android:textColor="@color/text_primary"
                            android:paddingVertical="14dp"
                            android:paddingStart="12dp"
                            android:inputType="textMultiLine"
                            android:fontFamily="sans-serif"
                            android:textSize="14sp"
                            android:minLines="3"
                            android:gravity="top|start" />
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Progress Bar (hidden by default) -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="8dp"
                android:visibility="gone"
                android:indeterminateTint="@color/primary_light" />

        </LinearLayout>
    </ScrollView>

</RelativeLayout>